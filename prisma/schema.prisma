generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Airdrop {
  id          Int      @id @default(autoincrement())
  name        String   
  description String?  
  link        String?  
  status      String   @default("NEW") 
  createdAt   DateTime @default(now())
}

model Note {
  id        Int      @id @default(autoincrement())
  text      String
  link      String?
  createdAt DateTime @default(now())
}

model Whale {
  id           Int        @id @default(autoincrement())
  address      String     @unique
  name         String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  transactions WhaleTx[]
}

model WhaleTx {
  id        Int      @id @default(autoincrement())
  signature String   @unique
  tokenMint String
  amount    Float
  type      String   
  timestamp DateTime @default(now())
  whaleId   Int?
  whale     Whale?   @relation(fields: [whaleId], references: [id])
}

model User {
  id             Int            @id @default(autoincrement())
  telegramId     String         @unique
  virtualBalance Float          @default(2000.0)
  trades         VirtualTrade[]
  createdAt      DateTime       @default(now())
}

model VirtualTrade {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  tokenMint  String
  symbol     String?
  entryPrice Float
  amountUAH  Float    @default(500.0)
  timestamp  DateTime @default(now())
  status     String   @default("OPEN") 
  exitPrice  Float?
  pnlUAH     Float?
  pnlPercent Float?
  closedAt   DateTime?
  report15m  Boolean @default(false)
  report1h   Boolean @default(false)
  report4h   Boolean @default(false)
  report12h  Boolean @default(false)
  report24h  Boolean @default(false)
}