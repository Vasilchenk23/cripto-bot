generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Airdrop {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  link        String?
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
}

model Note {
  id        Int      @id @default(autoincrement())
  text      String
  link      String?
  createdAt DateTime @default(now())
}

model Whale {
  id             Int             @id @default(autoincrement())
  address        String          @unique
  name           String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  transactions   WhaleTx[]
  observerTrades ObserverTrade[]
}

model WhaleTx {
  id        Int      @id @default(autoincrement())
  signature String   @unique
  tokenMint String
  amount    Float
  amountUSD Float?
  priceAtTx Float?
  type      String
  timestamp DateTime @default(now())
  whaleId   Int?
  whale     Whale?   @relation(fields: [whaleId], references: [id])
}

model ObserverTrade {
  id                Int      @id @default(autoincrement())
  whaleId           Int
  whale             Whale    @relation(fields: [whaleId], references: [id])
  tokenSymbol       String?
  mintAddress       String
  action            String
  usdAmount         Float
  entryPrice        Float
  timestamp         DateTime @default(now())
  signalReceivedAt  BigInt
  dbWrittenAt       BigInt?
  isLiquidityLocked Boolean?
  peak1m            Float?
  peak3m            Float?
  peak5m            Float?
  peak10m           Float?
  peak30m           Float?
}